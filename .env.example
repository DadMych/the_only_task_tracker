# Access tokens (generate with: npm run generate-tokens)
ACCESS_TOKEN_OWNER=
ACCESS_TOKEN_BOSS=

# App URL (optional, defaults to production)
APP_URL=https://the-only-task-tracker.vercel.app

# Turso (production on Vercel) — https://turso.tech
# Locally uses file:data/tracker.db if these are empty
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Telegram notifications (Oleksii only for now)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_OWNER=

# Screenshot storage (Vercel Blob — create in Vercel dashboard → Storage)
BLOB_READ_WRITE_TOKEN=
